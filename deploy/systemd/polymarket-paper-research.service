[Unit]
Description=Polymarket Paper Bot Autoresearch
After=network-online.target polymarket-paper-bot.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/obsidian-hermes-vault/projects/polymarket-5min-bot
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/root/obsidian-hermes-vault/projects/polymarket-5min-bot/.env
ExecStart=/root/obsidian-hermes-vault/projects/polymarket-5min-bot/.venv/bin/python /root/obsidian-hermes-vault/projects/polymarket-5min-bot/cli.py research --runtime-dir /root/obsidian-hermes-vault/projects/polymarket-5min-bot/data/runtime --artifact-dir /root/obsidian-hermes-vault/projects/polymarket-5min-bot/data/research --sample-limit 400
StandardOutput=journal
StandardError=journal
