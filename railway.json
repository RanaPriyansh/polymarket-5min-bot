{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "python api_wrapper.py",
    "healthcheckPath": "/health",
    "restartPolicy": {
      "type": "ON_FAILURE"
    },
    "environment": {
      "PORT": "8080",
      "PYTHONUNBUFFERED": "1"
    }
  }
}